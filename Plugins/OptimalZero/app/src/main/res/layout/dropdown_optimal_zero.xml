<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OPTIMAL ZERO"
                    android:textColor="#EEEEEE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MPBR BALLISTIC CALCULATOR"
                    android:textColor="#555555"
                    android:textSize="10sp"
                    android:letterSpacing="0.08" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8853;"
                android:textColor="#444444"
                android:textSize="28sp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="8dp" />

        <!-- ── Optic Type ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPTIC TYPE"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <Spinner
                android:id="@+id/spinner_optic"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/input_bg" />

        </LinearLayout>

        <!-- ── Weapon / Ammunition ────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WEAPON / AMMUNITION"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AMMUNITION"
                android:textColor="#555555"
                android:textSize="10sp"
                android:paddingBottom="3dp" />

            <Spinner
                android:id="@+id/spinner_ammo"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/input_bg"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BARREL LENGTH"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:paddingBottom="3dp" />

                    <Spinner
                        android:id="@+id/spinner_barrel"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/input_bg" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="MV OVERRIDE (fps)"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:paddingBottom="3dp" />

                    <EditText
                        android:id="@+id/edit_mv_override"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:inputType="numberDecimal"
                        android:hint="Auto"
                        android:textColor="#DDDDDD"
                        android:textColorHint="#444444"
                        android:textSize="@dimen/fontSize"
                        android:background="@drawable/input_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Optic Mount ────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPTIC MOUNT"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <RadioGroup
                android:id="@+id/radio_cowitness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <RadioButton
                    android:id="@+id/radio_absolute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Absolute"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"
                    android:buttonTint="#777777" />

                <RadioButton
                    android:id="@+id/radio_lower3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lower 1/3"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"
                    android:buttonTint="#777777" />

                <RadioButton
                    android:id="@+id/radio_other"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Other"
                    android:textColor="#BBBBBB"
                    android:textSize="12sp"
                    android:buttonTint="#777777"
                    android:checked="true" />

            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="HEIGHT OVER BORE (in)"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:paddingBottom="3dp" />

                    <EditText
                        android:id="@+id/edit_hob"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:inputType="numberDecimal"
                        android:textColor="#DDDDDD"
                        android:textSize="@dimen/fontSize"
                        android:background="@drawable/input_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RISER HEIGHT (in)"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:paddingBottom="3dp" />

                    <EditText
                        android:id="@+id/edit_riser"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:inputType="numberDecimal"
                        android:hint="0"
                        android:textColor="#DDDDDD"
                        android:textColorHint="#444444"
                        android:textSize="@dimen/fontSize"
                        android:background="@drawable/input_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Target ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TARGET"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VITAL ZONE (in)"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:paddingBottom="3dp" />

                    <EditText
                        android:id="@+id/edit_vital_zone"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:inputType="numberDecimal"
                        android:textColor="#DDDDDD"
                        android:textSize="@dimen/fontSize"
                        android:background="@drawable/input_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />

                </LinearLayout>

                <!-- Placeholder for symmetry -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Calculate Button ───────────────────────────────────────────── -->
        <Button
            android:id="@+id/btn_calculate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CALCULATE MPBR"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="#FFD700"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <!-- ── Solution ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SOLUTION"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:background="#0A0A0A"
                android:padding="10dp"
                android:minHeight="80dp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- ── Trajectory Chart ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TRAJECTORY"
                android:textColor="#888888"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:letterSpacing="0.1" />

            <com.optimalzero.ui.TrajectoryChartView
                android:id="@+id/chart_view"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#0A0A0A" />

        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
