<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- ══ SEARCH PANEL — hidden after fetch ════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:paddingStart="14dp"
            android:paddingEnd="4dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#CC2200"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CAMFEED"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⚙"
                android:textColor="#666666"
                android:textSize="16sp"
                android:background="@android:color/transparent"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btn_about"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="ⓘ"
                android:textColor="#666666"
                android:textSize="16sp"
                android:background="@android:color/transparent"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- Filter row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <RadioGroup
                android:id="@+id/rg_reference"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_map_center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Map"
                    android:textColor="#AAAAAA"
                    android:checked="true"
                    android:textSize="11sp"
                    android:buttonTint="#CC2200"/>

                <RadioButton
                    android:id="@+id/rb_my_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:buttonTint="#CC2200"/>
            </RadioGroup>

            <EditText
                android:id="@+id/et_radius"
                android:layout_width="44dp"
                android:layout_height="28dp"
                android:inputType="number"
                android:text="50"
                android:textColor="#FFFFFF"
                android:background="#2A2A2A"
                android:padding="4dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km"
                android:textColor="#555555"
                android:textSize="10sp"
                android:layout_marginEnd="10dp"/>

            <CheckBox
                android:id="@+id/cb_windy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="W"
                android:textColor="#AAAAAA"
                android:checked="true"
                android:textSize="11sp"
                android:buttonTint="#888888"/>

            <CheckBox
                android:id="@+id/cb_osm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O"
                android:textColor="#AAAAAA"
                android:checked="true"
                android:textSize="11sp"
                android:buttonTint="#888888"/>

            <CheckBox
                android:id="@+id/cb_kmz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="K"
                android:textColor="#AAAAAA"
                android:checked="true"
                android:textSize="11sp"
                android:buttonTint="#888888"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textColor="#555555"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- Fetch button — full width -->
        <Button
            android:id="@+id/btn_fetch"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="FETCH CAMERAS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="#CC2200"
            android:textSize="12sp"
            android:letterSpacing="0.05"/>

        <!-- Progress -->
        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CC2200"
            android:textSize="10sp"
            android:background="#111111"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone"/>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No cameras loaded"
            android:textColor="#555555"
            android:textSize="10sp"
            android:background="#111111"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- ══ RESULTS BAR — shown after fetch, hidden during search ════════════ -->
    <LinearLayout
        android:id="@+id/layout_results_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_back_search"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="◀ SEARCH"
            android:textColor="#CC2200"
            android:textStyle="bold"
            android:textSize="11sp"
            android:background="@android:color/transparent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#333333"/>

        <TextView
            android:id="@+id/tv_count_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 cameras"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:paddingStart="12dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Hidden count views still needed for code compatibility -->
        <TextView
            android:id="@+id/tv_count_windy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="W:0"
            android:textColor="#444444"
            android:textSize="9sp"
            android:paddingEnd="6dp"/>

        <TextView
            android:id="@+id/tv_count_osm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O:0"
            android:textColor="#444444"
            android:textSize="9sp"
            android:paddingEnd="6dp"/>

        <TextView
            android:id="@+id/tv_count_kmz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="K:0"
            android:textColor="#444444"
            android:textSize="9sp"
            android:paddingEnd="10dp"/>

    </LinearLayout>

    <!-- ══ FILTER TABS ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#1A1A1A">

        <Button android:id="@+id/btn_tab_all"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="All"
            android:textColor="#FFFFFF" android:background="@android:color/transparent"
            android:textSize="11sp" android:textStyle="bold"/>

        <Button android:id="@+id/btn_tab_windy"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="Windy"
            android:textColor="#AAAAAA" android:background="@android:color/transparent"
            android:textSize="11sp" android:alpha="0.5"/>

        <Button android:id="@+id/btn_tab_osm"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="OSM"
            android:textColor="#AAAAAA" android:background="@android:color/transparent"
            android:textSize="11sp" android:alpha="0.5"/>

        <Button android:id="@+id/btn_tab_kmz"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="KMZ"
            android:textColor="#AAAAAA" android:background="@android:color/transparent"
            android:textSize="11sp" android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#CC2200" android:alpha="0.4"/>

    <!-- ══ CAMERA LIST ════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scroll_cameras"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:background="#111111">

        <LinearLayout
            android:id="@+id/container_cameras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>
    </ScrollView>

    <!-- ══ EMPTY STATE ═══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#111111"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No cameras loaded"
            android:textColor="#2A2A2A"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a radius and tap Fetch"
            android:textColor="#222222"
            android:textSize="11sp"
            android:paddingTop="6dp"/>
    </LinearLayout>

</LinearLayout>
