<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#111111"
    android:layout_marginBottom="1dp">

    <!-- Source color bar -->
    <View
        android:id="@+id/view_source_bar"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#CC2200"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_source_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WIN"
                android:textColor="#888888"
                android:textSize="8sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_camera_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Camera Name"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingEnd="8dp"/>

            <Button
                android:id="@+id/btn_open_stream"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:background="#CC2200"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="3dp">

            <TextView
                android:id="@+id/tv_city"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Miami, FL"
                android:textColor="#555555"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="33.4484, -112.074"
                android:textColor="#333333"
                android:textSize="9sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_stream_type"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMBED"
            android:textColor="#333333"
            android:textSize="8sp"/>
    </LinearLayout>

</LinearLayout>
